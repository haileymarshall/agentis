{
  "name": "agentis",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:solidity": "hardhat test",
    "test:genlayer": ".venv/bin/pytest tests/test_agentis_judge_direct.py -v",
    "lint:genlayer": ".venv/bin/genvm-lint check contracts/agentis_judge.py",
    "build": "npm run compile && npm run build -w @agentis/shared && npm run build -w @agentis/backend && npm run build -w @agentis/frontend",
    "deploy:base-sepolia": "hardhat run scripts/deployAgentis.ts --network baseSepolia",
    "deploy:base-mainnet": "hardhat run scripts/deployAgentis.ts --network baseMainnet"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.5"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-verify": "^2.0.13",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.17.12",
    "chai": "^5.1.2",
    "hardhat": "^2.22.19",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
