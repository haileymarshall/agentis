# Chain RPCs
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Base contract addresses
BASE_SEPOLIA_AGENTIS_ADDRESS=0x_REPLACE_ME
BASE_MAINNET_AGENTIS_ADDRESS=0x_REPLACE_ME

# Start blocks for event scanning
BASE_SEPOLIA_START_BLOCK=0
BASE_MAINNET_START_BLOCK=0

# Separate Base relayer keys. Never reuse unless unavoidable.
BASE_SEPOLIA_RELAYER_PRIVATE_KEY=0x_REPLACE_ME
BASE_MAINNET_RELAYER_PRIVATE_KEY=0x_REPLACE_ME

# GenLayer
GENLAYER_ACCOUNT_PRIVATE_KEY=0x_REPLACE_ME
GENLAYER_NETWORK=studionet
GENLAYER_CONTRACT_ADDRESS=0x_REPLACE_ME
GENLAYER_RPC_URL=https://studio.genlayer.com/api

# Relay storage
RELAY_DB_PATH=./relay-state.json
RELAYER_PORT=8787

# Safety
SUPPORTED_CHAIN_IDS=84532,8453
DEFAULT_CHAIN_ID=84532
